{
  "manifest_version": 3,
  "name": "BetterYouTube - Enhanced YouTube",
  "version": "2.4.1",
  "description": "Take full control of your viewing experience. Block ads, hide Shorts, and personalize your layout instantly.",
  "content_security_policy": {
    "extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://cdn.jsdelivr.net https://fonts.gstatic.com data:; img-src 'self' data:; connect-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; object-src 'self'"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "BetterYouTube Settings"
  },
  "options_page": "popup.html",
  "options_ui": {
    "page": "popup.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "scripting",
    "declarativeNetRequest",
    "contextMenus"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.youtu.be/*",
    "*://returnyoutubedislikeapi.com/*",
    "*://sponsor.ajay.app/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/nonstop.js", "assets/audio_only.js"],
      "matches": ["*://*.youtube.com/*", "*://*.youtu.be/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*", "*://*.youtu.be/*"],
      "js": ["dist/content.bundle.js"],
      "run_at": "document_idle"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}